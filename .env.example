# ===========================================
#  BrainX Server — Environment Variables
# ===========================================
#  Copy this file to .env and fill in values
#  NEVER commit .env to version control!
# ===========================================

# ─── Server ────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ──────────────────────────────
# Get from: https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<pass>@cluster.mongodb.net/brainx
MONGO_URI=

# ─── JWT ───────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=30d

# ─── Client URL ────────────────────────────
# Your React app URL (comma-separated for multiple)
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:5000

# ─── Cloudinary ────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (Gmail SMTP) ────────────────────
# For Gmail: enable "App Passwords" in your Google account
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password

# ─── Alternative Email Providers ───────────
# SendGrid:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=your-sendgrid-api-key

# Resend:
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_USER=resend
# EMAIL_PASS=your-resend-api-key
